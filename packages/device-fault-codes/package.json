{
  "name": "@borochi/device-fault-codes",
  "version": "1.0.0",
  "description": "Device fault code data and utilities for inverter, wallbox, and heat pump devices",
  "keywords": [
    "fault-codes",
    "inverter",
    "wallbox",
    "heat-pump",
    "device",
    "error-handling"
  ],
  "license": "MIT",
  "author": "Borochi",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
